@model IEnumerable<HomeService.Models.Service>
@{
    ViewBag.Title = "Quản lý dịch vụ";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="section-title mb-0">Quản lý dịch vụ</h2>
            <p class="text-muted mt-1 mb-0" style="font-size:.85rem;">@Model.Count() dịch vụ</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Index","Admin")" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Quản lý đơn
            </a>
            <a href="@Url.Action("CreateService","Admin")" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Thêm dịch vụ
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-grid fs-1 text-muted"></i>
            <h5 class="mt-3 text-muted">Chưa có dịch vụ nào</h5>
            <a href="@Url.Action("CreateService","Admin")" class="btn btn-primary mt-3">Thêm dịch vụ đầu tiên</a>
        </div>
    }
    else
    {
        var serviceImages = new[] {
            "https://images.unsplash.com/photo-1621905251189-08b45d6a269e?w=100&q=60",
            "https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=100&q=60",
            "https://images.unsplash.com/photo-1581094794329-c8112a89af12?w=100&q=60",
            "https://images.unsplash.com/photo-1562259929-b4e1fd3aef09?w=100&q=60",
            "https://images.unsplash.com/photo-1581858726788-75bc0f6a952d?w=100&q=60",
            "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=100&q=60"
        };
        var si = 0;

        <div class="row g-3">
            @foreach(var s in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card service-card h-100">
                        <img src="@serviceImages[si % serviceImages.Length]" class="service-card-img" alt="@s.Title" style="height:160px;" />
                        <div class="card-body">
                            <span class="category-badge">@s.Category?.Name</span>
                            <h6 class="card-title mt-2 mb-1">@s.Title</h6>
                            <p class="card-text mb-2">@s.Description</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-primary fw-bold">@s.Price?.ToString("N0") đ</span>
                                <div class="d-flex gap-1">
                                    <a class="btn btn-sm btn-outline-primary" href="@Url.Action("EditService","Admin", new { id = s.Id })">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a class="btn btn-sm btn-outline-danger" href="@Url.Action("DeleteService","Admin", new { id = s.Id })"
                                       onclick="return confirm('Xoá dịch vụ này?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                si++;
            }
        </div>
    }
</div>
