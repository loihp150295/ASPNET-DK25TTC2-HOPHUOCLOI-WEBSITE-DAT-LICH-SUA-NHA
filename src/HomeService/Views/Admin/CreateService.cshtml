@model HomeService.Models.Service
@{
    ViewBag.Title = "Thêm dịch vụ";
}

<div class="container py-4">
    <div class="d-flex align-items-center gap-2 text-muted mb-4" style="font-size:.85rem;">
        <a href="@Url.Action("Services","Admin")" class="text-decoration-none text-muted">Quản lý dịch vụ</a>
        <i class="bi bi-chevron-right"></i>
        <span>Thêm dịch vụ</span>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card service-card p-4">
                <h4 class="fw-bold mb-4">
                    <i class="bi bi-plus-circle text-primary me-2"></i>Thêm dịch vụ mới
                </h4>

                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger py-2" style="font-size:.85rem;">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label fw-semibold" style="font-size:.88rem;">Tiêu đề dịch vụ *</label>
                        <input asp-for="Title" class="form-control" placeholder="VD: Sửa điện cơ bản" required />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold" style="font-size:.88rem;">Danh mục *</label>
                            <select asp-for="CategoryId" class="form-select" required>
                                <option value="">-- Chọn danh mục --</option>
                                @foreach(var c in ViewBag.Categories as List<HomeService.Models.Category>)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold" style="font-size:.88rem;">Giá (VNĐ) *</label>
                            <input asp-for="Price" class="form-control" placeholder="VD: 200000" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold" style="font-size:.88rem;">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="4"
                                  placeholder="Mô tả chi tiết dịch vụ..."></textarea>
                    </div>

                    <div class="d-flex gap-3">
                        <a href="@Url.Action("Services","Admin")" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-arrow-left me-1"></i>Quay lại
                        </a>
                        <button class="btn btn-success px-4 flex-grow-1" type="submit">
                            <i class="bi bi-check-lg me-2"></i>Lưu dịch vụ
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
