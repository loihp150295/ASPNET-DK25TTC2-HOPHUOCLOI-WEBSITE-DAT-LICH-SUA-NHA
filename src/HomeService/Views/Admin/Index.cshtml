@model IEnumerable<HomeService.Models.Booking>
@{
    ViewBag.Title = "Quản trị - Đơn đặt";
}


<div class="container pb-5">
    <div class="page-header" style="margin:0 -24px 2rem;padding-left:24px;padding-right:24px;border-radius:0;background:linear-gradient(135deg, #ef4444 0%, #dc2626 100%);">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <h1 style="font-size:1.75rem;"><i class="bi bi-shield-lock me-2"></i>Quản trị viên</h1>
                    <p>Quản lý đơn đặt dịch vụ — @Model.Count() đơn</p>
                </div>
                <div class="d-flex gap-2">
                    <a href="@Url.Action("Services","Admin")" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-grid me-1"></i>Dịch vụ
                    </a>
                    <a href="@Url.Action("Index","Home")" class="btn btn-light btn-sm text-dark">
                        <i class="bi bi-house me-1"></i>Website
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox fs-1" style="color:var(--gray-300);"></i>
            <h5 style="margin-top:1rem;color:var(--gray-500);">Chưa có đơn đặt nào</h5>
        </div>
    }
    else
    {
        <div class="table-modern">
            <table class="table table-modern mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Khách hàng</th>
                        <th>Dịch vụ</th>
                        <th>Ngày hẹn</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var b in Model)
                    {
                        <tr>
                            <td><span style="font-weight:700;color:var(--primary);">#@b.Id</span></td>
                            <td>
                                <div style="font-weight:600;font-size:.88rem;">@b.FullName</div>
                                <div style="font-size:.75rem;color:var(--gray-400);">@b.Phone</div>
                                <div style="font-size:.75rem;color:var(--gray-400);">@b.Address</div>
                            </td>
                            <td>
                                <div style="font-weight:600;font-size:.88rem;">@b.Service?.Title</div>
                                <div style="font-size:.75rem;color:var(--primary);font-weight:600;">
                                    @b.Service?.Price?.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN")) đ
                                </div>
                            </td>
                            <td style="font-size:.85rem;">@b.ScheduleDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @{
                                    var (badgeClass, badgeText) = b.Status switch
                                    {
                                        "Chờ xử lý" => ("badge-pending", "Chờ xử lý"),
                                        "Đang sửa" => ("badge-progress", "Đang sửa"),
                                        "Hoàn thành" => ("badge-done", "Hoàn thành"),
                                        _ => ("badge-pending", b.Status ?? "")
                                    };
                                }
                                <span class="badge-status @badgeClass">@badgeText</span>
                            </td>
                            <td style="font-size:.82rem;color:var(--gray-500);">@b.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a class="btn btn-sm @(b.Status == "Đang sửa" ? "btn-secondary disabled" : "btn-primary")"
                                       href="@Url.Action("UpdateStatus","Admin", new { id = b.Id, status = "Đang sửa" })"
                                       title="Đang sửa">
                                        <i class="bi bi-wrench"></i>
                                    </a>
                                    <a class="btn btn-sm @(b.Status == "Hoàn thành" ? "btn-secondary disabled" : "btn-success")"
                                       href="@Url.Action("UpdateStatus","Admin", new { id = b.Id, status = "Hoàn thành" })"
                                       title="Hoàn thành">
                                        <i class="bi bi-check-lg"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
